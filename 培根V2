-- 5. ESP 邏輯
local function CreateBaconESP(p)
    if p == player then return end
    local function apply()
        if espObjects[p.Name] then espObjects[p.Name]:Destroy() end
        local char = p.Character or p.CharacterAdded:Wait()
        if not ESP_Settings.Enabled then return end
        local h = Instance.new("Highlight")
        h.Name = "BaconESP"
        h.Adornee = char
        h.FillColor = Color3.fromRGB(170, 0, 255)
        h.OutlineColor = Color3.new(1, 1, 1)
        h.FillTransparency = 0.5
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Enabled = true
        h.Parent = game:GetService("CoreGui")
        espObjects[p.Name] = h
    end
    p.CharacterAdded:Connect(apply)
    if p.Character then apply() end
end
 
Players.PlayerAdded:Connect(function(newPlayer)
    if ESP_Settings.Enabled then CreateBaconESP(newPlayer) end
end)
 
