-- [[ 1. 播放函數：加上錯誤處理 ]] --
local function PlayRobloxID(id)
    if CurrentSound then 
        CurrentSound:Stop() 
        CurrentSound:Destroy() 
    end

    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://" .. tostring(id)
    s.Name = "BaconAudio"
    s.Volume = 2 -- 稍微大聲點
    s.Parent = game:GetService("SoundService")
    
    -- 檢查是否載入成功
    s.Loaded:Connect(function()
        s:Play()
        CurrentSound = s
        Rayfield:Notify({Title = "播放成功", Content = "正在播放 ID: " .. id, Duration = 2})
    end)
    
    -- 5秒後如果還沒播，提醒玩家可能 ID 壞了
    task.delay(5, function()
        if not s.IsPlaying then
            Rayfield:Notify({Title = "播放失敗", Content = "此 ID 可能被加密或非音訊檔", Duration = 3})
            s:Destroy()
        end
    end)
end


