-- [ 1. ESP 必要變數與設定 ]
local Settings = {
    Box_Thickness = 2,
    Autothickness = true
}
local allDrawings = {}
_G.Bacon_ESP_Enabled = false -- 全域開關
 
-- [ 2. 核心函數：計算血量顏色 ]
local function getHealthColor(ratio)
    ratio = math.clamp(ratio, 0, 1)
    return Color3.new(math.clamp((1 - ratio) * 2, 0, 1), math.clamp(ratio * 2, 0, 1), 0)
end
 
-- [ 3. 核心函數：創建 ESP 物件 ]
local function CreateAdvancedESP(plr)
    if plr == player then return end
 
    -- 創建繪圖物件
    local function NewLine()
        local l = Drawing.new("Line")
        l.Visible = false
        l.Thickness = Settings.Box_Thickness
        l.Transparency = 1
        table.insert(allDrawings, l)
        return l
    end
 
    local function NewText(size)
        local t = Drawing.new("Text")
        t.Visible = false
        t.Center = true
        t.Outline = true
        t.Size = size
        t.Font = Drawing.Fonts.UI
        t.Color = Color3.new(1,1,1)
        table.insert(allDrawings, t)
        return t
    end
 
    local Library = {
        TL1 = NewLine(), TL2 = NewLine(), TR1 = NewLine(), TR2 = NewLine(),
        BL1 = NewLine(), BL2 = NewLine(), BR1 = NewLine(), BR2 = NewLine()
    }
    local nameText = NewText(13)
    local hpText   = NewText(13)
    local distText = NewText(12)
 
    -- 輔助零件（用於計算 3D 座標）
    local oripart = Instance.new("Part")
    oripart.Transparency = 1
    oripart.CanCollide = false
    oripart.Anchored = true
    oripart.Parent = workspace
 
    local connection
    connection = game:GetService("RunService").RenderStepped:Connect(function()
        local char = plr.Character
        local hum  = char and char:FindFirstChild("Humanoid")
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
 
        -- 隱藏邏輯
        if not _G.Bacon_ESP_Enabled or not char or not hum or hum.Health <= 0 or not hrp then
            for _, v in pairs(Library) do v.Visible = false end
            nameText.Visible = false; hpText.Visible = false; distText.Visible = false
 
            if not game.Players:FindFirstChild(plr.Name) then
                for _, v in pairs(Library) do v:Remove() end
                nameText:Remove(); hpText:Remove(); distText:Remove(); oripart:Destroy()
                connection:Disconnect()
            end
            return
        end
 
        local _, onScreen = game.Workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
        if onScreen then
            local teamCol = plr.Team and plr.TeamColor.Color or Color3.new(1,1,1)
            oripart.Size = Vector3.new(hrp.Size.X, hrp.Size.Y * 1.5, hrp.Size.Z)
            oripart.CFrame = CFrame.new(hrp.CFrame.Position, game.Workspace.CurrentCamera.CFrame.Position)
 
            local SX, SY = oripart.Size.X, oripart.Size.Y
            local TL = game.Workspace.CurrentCamera:WorldToViewportPoint((oripart.CFrame * CFrame.new( SX,  SY, 0)).p)
            local TR = game.Workspace.CurrentCamera:WorldToViewportPoint((oripart.CFrame * CFrame.new(-SX,  SY, 0)).p)
            local BL = game.Workspace.CurrentCamera:WorldToViewportPoint((oripart.CFrame * CFrame.new( SX, -SY, 0)).p)
            local BR = game.Workspace.CurrentCamera:WorldToViewportPoint((oripart.CFrame * CFrame.new(-SX, -SY, 0)).p)
 
            local dist = (game.Workspace.CurrentCamera.CFrame.p - hrp.Position).Magnitude
            local offset = math.clamp(1/dist * 750, 2, 300)
 
            -- 更新線條
            local lines = {
                {Library.TL1, TL, Vector2.new(TL.X+offset, TL.Y)}, {Library.TL2, TL, Vector2.new(TL.X, TL.Y+offset)},
                {Library.TR1, TR, Vector2.new(TR.X-offset, TR.Y)}, {Library.TR2, TR, Vector2.new(TR.X, TR.Y+offset)},
                {Library.BL1, BL, Vector2.new(BL.X+offset, BL.Y)}, {Library.BL2, BL, Vector2.new(BL.X, BL.Y-offset)},
                {Library.BR1, BR, Vector2.new(BR.X-offset, BR.Y)}, {Library.BR2, BR, Vector2.new(BR.X, BR.Y-offset)}
            }
 
            for _, l in pairs(lines) do
                l[1].Visible = true; l[1].From = Vector2.new(l[2].X, l[2].Y); l[1].To = l[3]; l[1].Color = teamCol
                if Settings.Autothickness then l[1].Thickness = math.clamp(1/dist * 100, 1, 4) end
            end
 
            -- 更新文字
            local midX = (TL.X + TR.X) / 2
            nameText.Text = plr.DisplayName; nameText.Position = Vector2.new(midX, TL.Y - 16); nameText.Visible = true
            hpText.Text = math.floor(hum.Health).." 血量"; hpText.Position = Vector2.new(midX, math.max(BL.Y, BR.Y) + 4)
            hpText.Color = getHealthColor(hum.Health/hum.MaxHealth); hpText.Visible = true
            distText.Text = math.floor(dist).." 距離"; distText.Position = Vector2.new(midX, math.max(BL.Y, BR.Y) + 18); distText.Visible = true
        else
            for _, v in pairs(Library) do v.Visible = false end
            nameText.Visible = false; hpText.Visible = false; distText.Visible = false
        end
    end)
end
 
