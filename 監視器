-- [[ 4. 核心功能 ]] --
local function updateView()
    if #Cameras > 0 then
        local data = Cameras[CurrentIdx]
        cam.CameraType = Enum.CameraType.Scriptable
        cam.CFrame = data.cf
        CamNameLabel.Text = "頻道: " .. data.name
    else
        cam.CameraType = Enum.CameraType.Custom
        ScreenGui.Enabled = false
    end
end

-- 安裝工具 (使用專屬圖片)
local installTool = Instance.new("Tool")
installTool.Name = "🛠️ 安裝監視器"
installTool.TextureId = INSTALL_ICON or ""
installTool.RequiresHandle = false
installTool.Activated:Connect(function()
    local targetPos = mouse.Hit.p
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        tempCF = CFrame.lookAt(targetPos + Vector3.new(0, 1, 0), char.HumanoidRootPart.Position)
        ScreenGui.Enabled = true
        NameGui.Visible = true
    end
end)
installTool.Parent = backpack

ConfirmBtn.MouseButton1Click:Connect(function()
    local name = (NameInput.Text ~= "" and NameInput.Text) or ("Cam " .. #Cameras+1)
    table.insert(Cameras, {name = name, cf = tempCF})
    NameGui.Visible = false
    NameInput.Text = ""
end)

-- 面板工具 (使用專屬圖片)
local panelTool = Instance.new("Tool")
panelTool.Name = "📱 監視器面板"
panelTool.TextureId = PANEL_ICON or ""
panelTool.RequiresHandle = false
panelTool.Equipped:Connect(function()
    if #Cameras > 0 then
        ScreenGui.Enabled = true
        updateView()
    end
end)
panelTool.Unequipped:Connect(function()
    cam.CameraType = Enum.CameraType.Custom
    if not NameGui.Visible then ScreenGui.Enabled = false end
end)
panelTool.Parent = backpack

-- 切換與刪除邏輯
NextBtn.MouseButton1Click:Connect(function() if #Cameras > 0 then CurrentIdx = (CurrentIdx % #Cameras) + 1 updateView() end end)
PrevBtn.MouseButton1Click:Connect(function() if #Cameras > 0 then CurrentIdx = (CurrentIdx - 2 + #Cameras) % #Cameras + 1 updateView() end end)
DelBtn.MouseButton1Click:Connect(function() 
    if #Cameras > 0 then 
        table.remove(Cameras, CurrentIdx) 
        CurrentIdx = math.clamp(CurrentIdx, 1, math.max(1, #Cameras)) 
        updateView() 
    end 
end)

print("✅ 雙圖標監視系統已啟動！安裝與面板圖案已分開設定。")
