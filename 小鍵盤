CreateBtn.MouseButton1Click:Connect(function()
    local keyStr = TextBox.Text:upper()
    if keyStr == "" then return end
    
    local success, keyEnum = pcall(function() return Enum.KeyCode[keyStr] end)
    
    if success and keyEnum then
        buttonCount = (buttonCount + 1) % 10
        local FloatBtn = Instance.new("TextButton", ScreenGui)
        FloatBtn.Size = UDim2.new(0, 55, 0, 55)
        FloatBtn.Position = UDim2.new(0.4, buttonCount * 12, 0.4, buttonCount * 12)
        FloatBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        FloatBtn.BackgroundTransparency = 0.65
        FloatBtn.Text = keyStr
        FloatBtn.TextColor3 = Color3.new(0, 0, 0)
        FloatBtn.Font = Enum.Font.SourceSans
        FloatBtn.TextSize = 20

        Instance.new("UICorner", FloatBtn).CornerRadius = UDim.new(0.5, 0)
        local stroke = Instance.new("UIStroke", FloatBtn)
        stroke.Thickness = 1
        stroke.Color = Color3.new(0, 0, 0)

        makeDraggable(FloatBtn)

        FloatBtn.MouseButton1Down:Connect(function()
            if deleteMode then
                FloatBtn:Destroy()
            else
                FloatBtn.BackgroundTransparency = 0.3
                VirtualInputManager:SendKeyEvent(true, keyEnum, false, game)
            end
        end)

        FloatBtn.MouseButton1Up:Connect(function()
            if not deleteMode then
                FloatBtn.BackgroundTransparency = 0.65
                VirtualInputManager:SendKeyEvent(false, keyEnum, false, game)
            end
        end)
        
        TextBox.Text = ""
    end
end)
