
local stalkerId = 10788362273
local morphId = 10788206485
local player = game.Players.LocalPlayer
local ChatService = game:GetService("Chat")
local SoundService = game:GetService("SoundService")


local deathSoundId = "rbxassetid://94624102598882"


local chatMessages = {
    "嘿，別跑啊！",
    "回去工作！",
    "最好別讓我追到你!",
    "你逃不掉的，放棄吧..."
}


local function SafeMorph(char)
    if not char then return end
    local success, model = pcall(function()
        return game.Players:GetCharacterAppearanceAsync(morphId)
    end)
    if success and model then
        local shirt = char:FindFirstChildOfClass("Shirt") or Instance.new("Shirt", char)
        local pants = char:FindFirstChildOfClass("Pants") or Instance.new("Pants", char)
        local targetShirt = model:FindFirstChildOfClass("Shirt")
        local targetPants = model:FindFirstChildOfClass("Pants")
        
        if targetShirt then shirt.ShirtTemplate = targetShirt.ShirtTemplate end
        if targetPants then pants.PantsTemplate = targetPants.PantsTemplate end
        
        for _, item in pairs(char:GetChildren()) do
            if item:IsA("Accessory") then
                local handle = item:FindFirstChild("Handle")
                if handle then handle.Transparency = 1 end 
            end
        end
        for _, obj in pairs(model:GetChildren()) do
            if obj:IsA("Accessory") then obj.Parent = char
            elseif obj:IsA("BodyColors") then
                if char:FindFirstChild("BodyColors") then char.BodyColors:Destroy() end
                obj.Parent = char
            end
        end
    end
end

-- 2. 主召喚邏輯
local function SummonFarmOwner()
    if player.Character then SafeMorph(player.Character) end

    -- 召喚 NPC
    local success, stalkerModel = pcall(function()
        return game.Players:CreateHumanoidModelFromUserId(stalkerId)
    end)

    if success and stalkerModel then
        stalkerModel.Name = "農場主"
        stalkerModel.Parent = workspace
        
        local humanoid = stalkerModel:FindFirstChildOfClass("Humanoid")
        local root = stalkerModel:FindFirstChild("HumanoidRootPart")
        local head = stalkerModel:FindFirstChild("Head")
        
        humanoid.WalkSpeed = 15.5
        if root then root.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 40) end

        -- 動畫
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://913376220"
        local loadAnim = humanoid:LoadAnimation(anim)
        humanoid.Running:Connect(function(speed)
            if speed > 0.1 then if not loadAnim.IsPlaying then loadAnim:Play() end else loadAnim:Stop() end
        end)

        -- 說話
        task.spawn(function()
            while stalkerModel and humanoid and humanoid.Health > 0 do
                if head then
                    ChatService:Chat(head, chatMessages[math.random(1, #chatMessages)], Enum.ChatColor.Red)
                end
                task.wait(math.random(3, 5))
            end
        end)

        -- 死亡判定
        for _, part in pairs(stalkerModel:GetChildren()) do
            if part:IsA("BasePart") then
                part.Touched:Connect(function(hit)
                    if hit.Parent == player.Character then
                        local myHum = player.Character:FindFirstChildOfClass("Humanoid")
                        if myHum and myHum.Health > 0 then
                            myHum.Health = 0
                            
                            -- 死亡音效
                            local deathSFX = Instance.new("Sound")
                            deathSFX.SoundId = deathSoundId
                            deathSFX.Volume = 2
                            deathSFX.Parent = SoundService
                            deathSFX:Play()
                            deathSFX.Ended:Connect(function() deathSFX:Destroy() end)
                            
                            if head then ChatService:Chat(head, "我說了你跑不掉的😈", Enum.ChatColor.White) end
                            task.wait(2)
                            stalkerModel:Destroy()
                        end
                    end
                end)
            end
        end

        -- 追殺
        task.spawn(function()
            while stalkerModel and humanoid and humanoid.Health > 0 do
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    humanoid:MoveTo(player.Character.HumanoidRootPart.Position)
                end
                task.wait(0.2)
            end
        end)

        -- 通知
        if Rayfield then
            Rayfield:Notify({Title = "黑人逃跑", Content = "農場主已出現...", Duration = 3})
        end
    end
end

SummonFarmOwner()
